DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/rux_db
SQL_ECHO=false
LM_STUDIO_URL=http://127.0.0.1:1234
PLANNER_MODEL=qwen/qwen3-vl-4b
CRITIC_MODEL=mistralai/mistral-7b-instruct-v0.3
CRITIC_NON_BLOCKING=false
LOG_LEVEL=INFO
ENABLE_SCHEMA_REVISION_GUARD=false

# Security: API Authentication
API_KEY="dev-key-change-in-production"

# Input Validation: Max lengths (chars)
MAX_MESSAGE_LENGTH=1000
MAX_USER_ID_LENGTH=50
MAX_CORRECTION_LENGTH=500

# Rate Limiting: /chat endpoint
CHAT_RATE_LIMIT_REQUESTS=10
CHAT_RATE_LIMIT_WINDOW_SEC=60

# Rate Limiting : /debug endpoint
DEBUG_RATE_LIMIT_REQUESTS=50
DEBUG_RATE_LIMIT_WINDOW_SEC=60

# Rate Limiting : /feedback endpoint
FEEDBACK_RATE_LIMIT_REQUESTS=20
FEEDBACK_RATE_LIMIT_WINDOW_SEC=60